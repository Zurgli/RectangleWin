<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="TrayApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TrayApp.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Custom title bar: drag region + minimize + quit -->
        <Grid x:Name="TitleBarPanel" Height="40" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              VerticalAlignment="Top" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0" Spacing="10">
                <Image x:Name="TitleBarIcon" Source="ms-appx:///Assets/StoreLogo.png" Width="24" Height="24" />
                <TextBlock Text="RectangleWin" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <Button x:Name="MinimizeButton" Grid.Column="1" Width="46" Height="40" MinWidth="46"
                    Background="Transparent" BorderThickness="0" CornerRadius="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Padding="0" Click="OnMinimizeClick" ToolTipService.ToolTip="Minimize to tray">
                <FontIcon Glyph="&#xE921;" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
            <Button x:Name="QuitButton" Grid.Column="2" Width="46" Height="40" MinWidth="46"
                    Background="Transparent" BorderThickness="0" CornerRadius="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Padding="0" Click="OnQuitClick" ToolTipService.ToolTip="Quit">
                <FontIcon Glyph="&#xE8BB;" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
        </Grid>
        <ScrollViewer Grid.Row="1" x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" Padding="24,20" HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="MainContentPanel" Spacing="24" MaxWidth="500" HorizontalAlignment="Center">
            <!-- Title -->
            <StackPanel Spacing="2">
                <TextBlock FontSize="22" FontWeight="Bold" Text="RectangleWin" />
                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Window snapping with keyboard shortcuts" />
            </StackPanel>

            <!-- Settings (moved up) -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Settings" />
                    <Grid ColumnSpacing="16" RowSpacing="10" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="13" Text="Launch at startups" VerticalAlignment="Center" HorizontalAlignment="Left" TextWrapping="NoWrap" />
                        <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
                            <ToggleSwitch x:Name="LaunchOnLoginCheckBox" MinWidth="30" OffContent="" OnContent="" Toggled="OnLaunchOnLoginToggled"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <TextBlock FontSize="13" Text="Gaps between windows" VerticalAlignment="Center" TextWrapping="NoWrap" />
                            <Button Width="20" Height="20" MinWidth="20" MinHeight="20" Padding="0" Background="Transparent" BorderThickness="0" CornerRadius="10" IsTabStop="False"
                                ToolTipService.ToolTip="Negative = overdraw to hide semi-transparent window edges."
                                ToolTipService.Placement="Top">
                                <TextBlock FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="?" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <!-- Slider track is inset by thumb padding; 0 is at ~35/120 (inset + 8/32 of track) -->
                            <Grid Width="120" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35*" />
                                    <ColumnDefinition Width="85*" />
                                </Grid.ColumnDefinitions>
                                <!-- Tick at 0 px -->
                                <Border Grid.Column="0" Width="2" HorizontalAlignment="Right" VerticalAlignment="Stretch" IsHitTestVisible="False"
                                    Background="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.8" Margin="0,4" MinHeight="20" />
                                <Slider x:Name="GapSlider" Grid.ColumnSpan="2" Width="120" Minimum="-8" Maximum="24" StepFrequency="1"
                                    ValueChanged="OnGapValueChanged" VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock x:Name="GapValueText" FontSize="13" FontWeight="SemiBold" Text="0 px" VerticalAlignment="Center" MinWidth="36" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Shortcuts (two columns) -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Shortcuts" />
                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                            Text="Win+Alt. Edit config.json to change keys." />
                    </StackPanel>
                    <Grid ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,20,0">
                            <StackPanel x:Name="ShortcutsListLeft" Spacing="2" />
                        </ScrollViewer>
                        <Border Grid.Column="1" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" VerticalAlignment="Stretch" />
                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="20,0,0,0">
                            <StackPanel x:Name="ShortcutsListRight" Spacing="2" />
                        </ScrollViewer>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Feedback -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Text="Last shortcut:" />
                    <TextBlock x:Name="LastHotkeyText" Grid.Column="1" FontSize="12" VerticalAlignment="Center" Text="(none yet)" />
                </Grid>
            </Border>

            <!-- Footer -->
            <StackPanel Spacing="4">
                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                    Text="Edit raw settings (hotkeys, gaps, etc.) in JSON:" />
                <HyperlinkButton x:Name="OpenConfigLink" Content="Open config.json" FontSize="12" FontWeight="SemiBold"
                    Foreground="{StaticResource PrimaryBrush}" Padding="0,2,0,0" HorizontalAlignment="Left" Click="OnOpenConfigClick" />
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
