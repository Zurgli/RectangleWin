<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="TrayApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TrayApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Content>
        <StackPanel Padding="24" Spacing="12">
            <TextBlock FontSize="18" Style="{StaticResource MyLabel}" Text="RectangleWin" />
            <TextBlock Text="Hotkeys active. Transformer: Win+Alt" TextWrapping="Wrap" />
            <TextBlock Text="1 Left  2 Right  3 Top  4 Bottom  5 Maximize  6 Center" TextWrapping="Wrap" />
            <TextBlock Text="Q UpperLeft  W UpperRight  A LowerLeft  S LowerRight" TextWrapping="Wrap" />
            <TextBlock Text="N Next display  P Previous display  R Restore" TextWrapping="Wrap" />
            <Border Margin="0,16,0,0" Padding="12" Background="#20FFFFFF" CornerRadius="4">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="Last key press" />
                    <TextBlock x:Name="LastHotkeyText" Text="(none yet)" />
                    <TextBlock FontSize="12" Opacity="0.8" Text="Press Win+Alt + a key (e.g. 1, 2, Q) to test" />
                </StackPanel>
            </Border>
            <TextBlock Margin="0,12,0,0" Text="Close this window to exit." />
        </StackPanel>
    </Page.Content>
</Page>
